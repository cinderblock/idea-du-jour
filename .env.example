# Copy to .env for local dev. The real .env is gitignored.

# libsql database URL. Local file for dev; a mounted volume path in the container.
DATABASE_URL=file:./data/idj.db

# WebAuthn relying-party (auth phase). Use idj.isozilla.com in production.
RP_ID=localhost
RP_NAME=idea-du-jour

# Agent enrichment (async classify/tag/summarize of captures via Claude).
# Without a key, enrichment is skipped and the app works normally.
# ANTHROPIC_API_KEY=sk-ant-...
ENRICH_MODEL=claude-sonnet-5
ENRICH_ENABLED=true
