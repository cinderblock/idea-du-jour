# Copy to .env for local dev. The real .env is gitignored.

# libsql database URL. Local file for dev; a mounted volume path in the container.
DATABASE_URL=file:./data/idj.db

# WebAuthn / session. In production use RP_ID=idj.isozilla.com and
# RP_ORIGIN=https://idj.isozilla.com, and set a strong random SESSION_SECRET.
RP_ID=localhost
RP_NAME=idea-du-jour
RP_ORIGIN=http://localhost:3000
# Sign session + challenge cookies. REQUIRED in prod (e.g. `openssl rand -hex 32`).
SESSION_SECRET=dev-insecure-session-secret-change-me

# Agent enrichment (async classify/tag/summarize of captures via Claude).
# Without a key, enrichment is skipped and the app works normally.
# ANTHROPIC_API_KEY=sk-ant-...
ENRICH_MODEL=claude-sonnet-5
ENRICH_ENABLED=true
